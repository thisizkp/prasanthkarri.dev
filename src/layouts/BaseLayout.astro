---
import Header from '@/components/Header.astro'
import BackToTop from '@/components/BackToTop.astro'
import '@/styles/global.css'

interface Props {
  title?: string
  description?: string
  type?: 'website' | 'article'
  publishedTime?: string
  modifiedTime?: string
}

const {
  title = 'Prasanth Karri',
  description = 'Personal blog by KP - systems, math, and whatever pulls me.',
  type = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props

const site = Astro.site ?? new URL('https://prasanthkarri.dev')
const pageTitle = title === 'Prasanth Karri' ? title : `${title} | Prasanth Karri`
const canonical = new URL(Astro.url.pathname, site)
const ogImage = new URL('/og.svg', site)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      const storedTheme = localStorage.getItem('theme')
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      if (storedTheme === 'dark' || (!storedTheme && systemPrefersDark)) {
        document.documentElement.classList.add('dark')
      }
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="KP's Writings" href="/rss.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
  </head>
  <body>
    <div class="site-shell">
      <a href="#main" class="skip-link">Skip to main content</a>
      <Header />
      <main id="main" class="main">
        <slot />
      </main>
      <BackToTop />
    </div>
    <script>
      const themeToggle = document.querySelector<HTMLButtonElement>('.theme-toggle')

      function syncThemeIcon() {
        const isDark = document.documentElement.classList.contains('dark')
        document.querySelector<SVGElement>('.theme-icon-moon')?.classList.toggle('is-hidden', isDark)
        document.querySelector<SVGElement>('.theme-icon-sun')?.classList.toggle('is-hidden', !isDark)
      }

      themeToggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark')
        localStorage.setItem('theme', isDark ? 'dark' : 'light')
        syncThemeIcon()
      })

      syncThemeIcon()
    </script>
  </body>
</html>
